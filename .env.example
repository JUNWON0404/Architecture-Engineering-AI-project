# 환경 변수 설정 (.env.example)

# ── 서버 설정 ──────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── 데이터베이스 (PostgreSQL / Supabase) ────────────────────
# 연결 문자열 형식: postgres://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgres://postgres:PASSWORD@db.glouiysqkbjuaylpggba.supabase.co:5432/postgres

# ── 인증 (Auth) ─────────────────────────────────────────────
# 세션/쿠키 암호화 키 (임의의 긴 문자열)
SESSION_SECRET=your-very-secure-secret-key-here

# ── 외부 서비스 (선택 사항) ───────────────────────────────
# Google Maps API (현재 미사용)
GOOGLE_MAPS_API_KEY=

# Image Generation (OpenAI / Stability AI 등)
IMAGE_GEN_API_KEY=

# Voice Transcription (Whisper 등)
VOICE_API_KEY=
