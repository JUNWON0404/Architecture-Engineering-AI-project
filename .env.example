# 개발 환경 설정 (최소 필수 변수)

# 노드 환경
NODE_ENV=development

# 데이터베이스 (필수: 이메일 로그인을 위해 필요)
# MySQL 예시: mysql://user:password@localhost:3306/database_name
DATABASE_URL=

# JWT 시크릿 (세션 쿠키 암호화)
JWT_SECRET=your-secret-key-here-min-32-chars

# OAuth 서버 URL (OAuth 사용 시 필요)
OAUTH_SERVER_URL=

# 앱 ID
VITE_APP_ID=

# 관리자 계정 (OAuth 로그인 시)
OWNER_OPEN_ID=

# 포지/AI API (선택사항)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Google Sheets (선택사항)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=
