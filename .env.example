# 개발 환경 설정 (로컬 실행용 기본값)

# 노드 환경
NODE_ENV=development

# 데이터베이스 (기본값: 로컬 SQLite 파일 사용)
DATABASE_URL=file:./db.sqlite

# JWT 시크릿 (로컬 테스트용 기본 키)
JWT_SECRET=local-dev-secret-key-at-least-32-characters-long

# OAuth 서버 URL (필요 시 수정)
OAUTH_SERVER_URL=http://localhost:3000

# 앱 ID (기본값)
VITE_APP_ID=job-ready-local

# 관리자 계정 (OAuth 로그인 미사용 시 무시 가능)
OWNER_OPEN_ID=

# 포지/AI API (선택사항)
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# Google Sheets (현재 미사용)
GOOGLE_SHEETS_SPREADSHEET_ID=
GOOGLE_APPLICATION_CREDENTIALS=
