# 환경 변수 설정 가이드 (.env.example)
# 이 파일을 .env로 복사한 뒤 실제 값을 입력하세요.

# ── 서버 설정 ──────────────────────────────────────────────
NODE_ENV=development
JWT_SECRET=your_jwt_secret_here
SESSION_SECRET=your_session_secret_here
OAUTH_SERVER_URL=your_oauth_server_url_here

# ── 데이터베이스 (PostgreSQL / Supabase) ────────────────────
# 연결 문자열 형식: postgres://postgres:[PASSWORD]@[HOST]:5432/postgres
DATABASE_URL=postgres://postgres:PASSWORD@your_host.supabase.co:5432/postgres

# ── 클라이언트 설정 (Vite 기반) ──────────────────────────────
VITE_ANALYTICS_ENDPOINT=your_analytics_endpoint_here
VITE_ANALYTICS_WEBSITE_ID=your_analytics_website_id_here
VITE_OAUTH_PORTAL_URL=your_oauth_portal_url_here
VITE_APP_ID=your_app_id_here

# ── 기타 설정 ─────────────────────────────────────────────
OWNER_OPEN_ID=your_owner_open_id_here
BUILT_IN_FORGE_API_URL=your_forge_api_url_here
BUILT_IN_FORGE_API_KEY=your_forge_api_key_here
